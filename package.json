{
  "name": "vitest",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:stories": "vitest run --project=storybook",
    "test:unit": "vitest run --project=unit",
    "test:coverage": "vitest run --project=storybook --coverage",
    "stories:check": "node scripts/check-stories.mjs",
    "stories:generate": "node scripts/generate-stories.mjs",
    "scan": "node platform/cli.mjs scan",
    "generate": "node platform/cli.mjs generate",
    "dashboard": "node platform/cli.mjs dashboard",
    "ai": "node platform/cli.mjs ai",
    "test:platform": "node --test 'platform/__tests__/*.test.mjs'",
    "ftap:selftest": "node --test 'platform/__tests__/*.test.mjs'",
    "e2e": "playwright test --grep-invert @visual",
    "e2e:visual": "playwright test --grep @visual --project=chromium",
    "e2e:visual:update": "playwright test --grep @visual --project=chromium --update-snapshots",
    "e2e:report": "playwright show-report",
    "bdd": "NODE_OPTIONS=\"--import tsx/esm\" cucumber-js",
    "bdd:dry": "NODE_OPTIONS=\"--import tsx/esm\" cucumber-js --dry-run"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@cucumber/cucumber": "^13.0.0",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-onboarding": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "oxlint": "^1.69.0",
    "playwright": "^1.61.1",
    "storybook": "^10.4.6",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
